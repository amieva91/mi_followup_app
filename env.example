# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=sqlite:///instance/followup.db

# Email (Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=followup.fit@gmail.com
MAIL_PASSWORD=your-app-password-here

# Application
APP_NAME=FollowUp
ITEMS_PER_PAGE=20
# Cache del dashboard (minutos). 10080 = 1 semana. Por defecto 15 si no se define.
# DASHBOARD_CACHE_MINUTES=10080

# Gemini AI (informes, resumen "About the Company", audio TTS)
# Crea la clave en https://aistudio.google.com/apikey o en Cloud Console; NO la subas a Git (revocan claves filtradas).
GEMINI_API_KEY=your-gemini-api-key-here

# Modelos Gemini (opcional - valores por defecto si no se definen)
# GEMINI_MODEL_FLASH=gemini-2.5-flash
# GEMINI_MODEL_TTS=gemini-3.1-flash-tts-preview
# GEMINI_AGENT_DEEP_RESEARCH=deep-research-preview-04-2026
# (Max: deep-research-max-preview-04-2026 — más lento; puede requerir más cuota o tiempo)

